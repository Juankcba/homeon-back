# ═══════════════════════════════════════════════════════════
# HomeOn Backend - Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────
PORT=3005
NODE_ENV=production

# ─── Database (PostgreSQL via Docker) ─────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=homeon
DB_PASSWORD=CHANGE_ME_secure_password_here
DB_DATABASE=homeon

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_EXPIRATION=24h

# ─── Redis (via Docker) ──────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# ─── Tapo Cameras ────────────────────────────────────────
# Your TP-Link cloud account credentials
TAPO_USERNAME=your_tapo_email@example.com
TAPO_PASSWORD=your_tapo_password

# ─── Philips Hue (se configura desde la app después) ─────
# Valores iniciales opcionales; se sobreescriben desde la UI
HUE_BRIDGE_IP=
HUE_API_KEY=

# ─── Gate Controller (MQTT via Mosquitto) ─────────────────
GATE_CONTROLLER_IP=192.168.1.200
GATE_CONTROLLER_PORT=8080

# ─── AI Engine ────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:5000
AI_ENGINE_TIMEOUT=10000
AI_API_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ─── AI Tuning ───────────────────────────────────────────
AI_FRAME_INTERVAL=5
AI_YOLO_CONF=0.45
AI_FACE_TOLERANCE=0.55

# ─── Cloudflare Tunnel ───────────────────────────────────
# Token del tunnel creado en Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ─── CORS ─────────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
CORS_ORIGIN=http://localhost:3000,https://www.domotichomes.com,https://domotichomes.com
